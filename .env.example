# Application Settings
APP_NAME=CodeAura
APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO

# Server Settings
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Database Settings
DATABASE_URL=postgresql://postgres:password@localhost:5432/codeaura
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30

# Redis Settings
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Security Settings
SECRET_KEY=your-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Provider Settings
# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_TOKENS=2000

# Alternative: Ollama (Local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Alternative: Google Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-pro

# Analysis Settings
MAX_CODE_SIZE_KB=1024
ANALYSIS_TIMEOUT_SECONDS=30
CACHE_TTL_HOURS=24

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_WINDOW_MINUTES=1

# Email Settings (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@codeaura.com

# Storage Settings
UPLOAD_FOLDER=./uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_EXTENSIONS=py,c,cpp,h,hpp,java,js,ts,jsx,tsx,go,rust,rs,php,rb,swift,kotlin,kt,scala,cs

# Monitoring
SENTRY_DSN=
PROMETHEUS_ENABLED=True
METRICS_ENDPOINT=/metrics

# CORS Settings
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
CORS_CREDENTIALS=True
CORS_METHODS=["*"]
CORS_HEADERS=["*"]
